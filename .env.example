# ─────────────────────────────────────────────────────────────────
# Jules PR Reviewer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── GitHub App ────────────────────────────────────────────────────
# Your GitHub App ID (found in App settings page)
GITHUB_APP_ID=123456

# Your GitHub App private key (PEM format)
# Paste the full contents of the .pem file downloaded from GitHub App settings
# Replace actual newlines with \n when putting in a single line env var
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — a random string you set when creating the GitHub App
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Jules API ─────────────────────────────────────────────────────
# Get your API key from: https://jules.google.com/settings#api
JULES_API_KEY=your_jules_api_key_here

# Jules API base URL (do not change)
JULES_BASE_URL=https://jules.googleapis.com/v1alpha

# ── Server ────────────────────────────────────────────────────────
PORT=8000

# ── Review Config ─────────────────────────────────────────────────
REVIEW_TIMEOUT_SECS=600
POLL_INTERVAL_SECS=15
MAX_RETRIES=3
SKIP_DRAFT_PRS=true
